# Database
# For docker environment: postgresql+asyncpg://postgres:postgres@localhost:5432/projectmatchai
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/projectmatchai

# Authentication & Security
# Generate using: openssl rand -hex 32
JWT_SECRET_KEY=placeholder_secret_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# AI Configuration (groq | ollama)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Embeddings & Reranking
BGE_MODEL_NAME=BAAI/bge-m3

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Development Setup
FRONTEND_PORT=5173
BACKEND_PORT=8000
