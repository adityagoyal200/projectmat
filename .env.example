# Database
# For docker environment: postgresql+asyncpg://postgres:postgres@localhost:5432/projectmatchai
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/projectmatchai


# AI Configuration
# Provider options: ollama (free/local), groq, gemini, openai
LLM_PROVIDER=ollama
# Keep false until you test with POST /api/matching/llm-preview or the dashboard LLM panel.
# When false, matching endpoints return 503 — no dummy scores are generated.
LLM_ENABLED=true
# Log prompts and responses to the backend console
LLM_LOG_RESPONSES=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings (pip install sentence-transformers for BGE-M3; token fallback if disabled/unavailable)
BGE_MODEL_NAME=BAAI/bge-m3
EMBEDDINGS_ENABLED=true

# Two-stage matching: LLM deep-eval on top-K preliminary results
MATCH_LLM_TOP_K=10

# Scoring v2.0 — growth potential weighted highest
SCORING_VERSION=2.0.0
SCORE_WEIGHT_EMBEDDING_SIMILARITY=0.15
SCORE_WEIGHT_READINESS=0.20
SCORE_WEIGHT_GROWTH_POTENTIAL=0.30
SCORE_WEIGHT_INTEREST=0.10
SCORE_WEIGHT_PREREQUISITE_OVERLAP=0.15
SCORE_WEIGHT_RESUME_EXPERIENCE=0.10

# Development Setup
FRONTEND_PORT=5173
BACKEND_PORT=8000


EMBEDDINGS_ENABLED=true
MATCH_LLM_TOP_K=10
