# Environment
ENV=development

# Database
# For docker environment: postgresql+asyncpg://postgres:postgres@localhost:5432/projectmatchai
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/projectmatchai

# AI Configuration
# Provider options: ollama, groq, gemini, openai
LLM_PROVIDER=ollama
LLM_ENABLED=true
LLM_LOG_RESPONSES=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings
BGE_MODEL_NAME=BAAI/bge-m3
EMBEDDINGS_ENABLED=true
HF_TOKEN=

# Two-stage matching
MATCH_LLM_TOP_K=10
MATCH_SIGNAL_CONCURRENCY=8
MATCH_RESPONSE_CACHE_TTL_SECONDS=120

# Hybrid scoring v3.1.0
SCORING_VERSION=3.1.0
SCORE_WEIGHT_EMBEDDING_SIMILARITY=0.15
SCORE_WEIGHT_PREREQUISITE_OVERLAP=0.20
SCORE_WEIGHT_RESUME_EXPERIENCE=0.20
SCORE_WEIGHT_GITHUB=0.30
SCORE_WEIGHT_CODING_PROFILES=0.05
SCORE_WEIGHT_ACHIEVEMENTS=0.05
SCORE_WEIGHT_LLM_FIT=0.05

# Repository and profile integrations
GITHUB_TOKEN=
GITLAB_TOKEN=

# External browser/code agent orchestration
AGY_COMMAND=agy
AGY_MODEL=Gemini 3.5 Flash (Low)
AGY_PRINT_TIMEOUT=30m0s
AGY_CALLBACK_BASE_URL=http://localhost:8000

# Live app evaluation
LIVE_LINK_TIMEOUT=5

# Local dev ports
FRONTEND_PORT=5173
BACKEND_PORT=8000

# --- Docker Compose deployment (docker compose up -d --build) ---
# Host-side ports — change these if they collide with other projects on the VM.
DB_HOST_PORT=5432
OLLAMA_HOST_PORT=11434
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=5173

# URL the browser uses to reach the backend API; baked into the frontend
# build, so it must be reachable from outside the VM (not "db"/"backend"
# container names). e.g. http://<VM_IP>:8000
VITE_API_URL=http://localhost:8000

# Comma-separated extra origins allowed to call the API, e.g.
# http://<VM_IP>:5173
EXTRA_CORS_ORIGINS=
